# SecLLM – desenvolvimento com hot-reload (cargo-watch)
# Montar código com volume e rodar: cargo watch -x run

FROM rust:1-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev \
    && rm -rf /var/lib/apt/lists/*

RUN cargo install cargo-watch

WORKDIR /app

# Código é montado via volume em runtime; cópia inicial para ter deps
COPY Cargo.toml Cargo.lock ./
COPY config ./config
COPY src ./src

# Reduz uso de RAM no link (evita OOM em VMs com pouca memória)
ENV CARGO_BUILD_JOBS=1 RUSTFLAGS="-C codegen-units=1"
# Sem RUN cargo build: camada pesada causa I/O error ao commit no BuildKit. Primeira compilação ao subir o container.

CMD ["cargo", "watch", "-x", "run", "-w", "src", "-w", "config", "-w", "Cargo.toml"]
